<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:width="42dp"
        android:height="25dp"
        android:gravity="top|center_horizontal"
        android:top="10dp"
        android:left="4dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#FFF4FAFF"
                android:centerColor="#FFCEE3F4"
                android:endColor="#FF9CB7D5" />
        </shape>
    </item>

    <item
        android:width="36dp"
        android:height="22dp"
        android:gravity="top|center_horizontal"
        android:top="13dp"
        android:right="7dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#FFF6FBFF"
                android:centerColor="#FFD5E8F7"
                android:endColor="#FFABC4DD" />
        </shape>
    </item>

    <item
        android:width="10dp"
        android:height="10dp"
        android:gravity="bottom|center_horizontal"
        android:bottom="4dp"
        android:left="9dp"
        android:drawable="@drawable/ic_weather_crystal_faceted" />

    <item
        android:width="12dp"
        android:height="12dp"
        android:gravity="bottom|center_horizontal"
        android:bottom="0dp"
        android:drawable="@drawable/ic_weather_crystal_faceted" />

    <item
        android:width="9dp"
        android:height="9dp"
        android:gravity="bottom|center_horizontal"
        android:bottom="6dp"
        android:right="10dp"
        android:drawable="@drawable/ic_weather_crystal_faceted" />
</layer-list>
