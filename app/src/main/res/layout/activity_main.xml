<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainBackground"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_holo_base"
    tools:context=".MainActivity">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_holo_space" />

    <com.example.weather.ui.WeatherEffectOverlayView
        android:id="@+id/weatherEffectView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:importantForAccessibility="no" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/mainScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="120dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/cityHeaderGroup"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/cityMetaText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.82"
                            android:fontFamily="sans-serif-medium"
                            android:text="Current location"
                            android:textColor="@color/text_neon_dim"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/cityNameText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="sans-serif-black"
                            android:textColor="@android:color/white"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            tools:text="City" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/manageCityButton"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_glass_button"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="42dp"
                        android:text="@string/manage_city_clean"
                        android:textColor="@color/text_primary"
                        app:backgroundTint="@android:color/transparent"
                        app:cornerRadius="20dp"
                        app:strokeWidth="0dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/updateTimeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:alpha="0.56"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    tools:text="Updated 19:19" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/stateCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/glass_state_bg"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#4CFFFFFF"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingTop="14dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="14dp">

                        <ProgressBar
                            android:id="@+id/loadingProgress"
                            style="?android:attr/progressBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:indeterminateTint="@color/text_primary" />

                        <TextView
                            android:id="@+id/stateText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            tools:text="Syncing weather..." />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/retryButton"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_glass_button"
                            android:text="Retry"
                            android:textColor="@color/text_primary"
                            android:visibility="gone"
                            app:backgroundTint="@android:color/transparent"
                            app:cornerRadius="20dp"
                            app:strokeWidth="0dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/weatherContentLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="vertical"
                    android:visibility="invisible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/currentTempText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-black"
                                android:includeFontPadding="false"
                                android:textColor="#F5FFFFFF"
                                android:textSize="108sp"
                                android:textStyle="bold"
                                tools:text="26 deg" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="-4dp"
                                android:background="@drawable/bg_condition_tag"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="14dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="&#9679;"
                                    android:textColor="@color/text_neon_primary"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/weatherConditionText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:textColor="@color/text_primary"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    tools:text="Cloudy" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/currentSummaryText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:lineSpacingExtra="3dp"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                tools:text="Cloudy, feels like 24 deg." />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <FrameLayout
                                android:layout_width="96dp"
                                android:layout_height="92dp"
                                android:layout_marginBottom="8dp"
                                android:foregroundGravity="center">

                                <ImageView
                                    android:id="@+id/dayNightStickerImage"
                                    android:layout_width="84dp"
                                    android:layout_height="84dp"
                                    android:layout_gravity="center"
                                    android:adjustViewBounds="true"
                                    android:contentDescription="Day night sticker"
                                    android:rotation="-4"
                                    android:scaleType="fitCenter"
                                    tools:src="@drawable/sticker_sun" />
                            </FrameLayout>

                            <FrameLayout
                                android:layout_width="120dp"
                                android:layout_height="120dp"
                                android:background="@drawable/bg_holo_weather_orb">

                                <com.example.weather.ui.HolographicImageView
                                    android:id="@+id/weatherIcon"
                                    android:layout_width="80dp"
                                    android:layout_height="80dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/home_weather_orb"
                                    tools:src="@drawable/ic_weather_fallback_cloudy" />

                                <View
                                    android:layout_width="10dp"
                                    android:layout_height="10dp"
                                    android:layout_gravity="top|end"
                                    android:layout_marginTop="18dp"
                                    android:layout_marginEnd="20dp"
                                    android:background="@drawable/bg_holo_clothing_orb" />

                                <View
                                    android:layout_width="7dp"
                                    android:layout_height="7dp"
                                    android:layout_gravity="bottom|start"
                                    android:layout_marginStart="18dp"
                                    android:layout_marginBottom="18dp"
                                    android:background="@drawable/bg_holo_clothing_orb" />
                            </FrameLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_holo_metric_strip"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingTop="14dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_metric_feels_like_symbol"
                                android:textColor="@color/text_neon_primary"
                                android:textSize="15sp" />

                            <TextView
                                android:id="@+id/feelsLikeValueText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="20 deg" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="24dp"
                            android:alpha="0.28"
                            android:background="#7AFFFFFF" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_metric_humidity_symbol"
                                android:textColor="@color/text_neon_primary"
                                android:textSize="15sp" />

                            <TextView
                                android:id="@+id/humidityValueText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="58%" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="24dp"
                            android:alpha="0.28"
                            android:background="#7AFFFFFF" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.1"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_metric_wind_symbol"
                                android:textColor="@color/text_neon_primary"
                                android:textSize="15sp" />

                            <TextView
                                android:id="@+id/windValueText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="South wind level 2" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_holo_section_pill"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:text="@string/home_weather_indices_title"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@drawable/bg_holo_index_panel"
                                android:orientation="vertical"
                                android:paddingStart="16dp"
                                android:paddingTop="14dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/home_index_precip"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/indexPrecipValueText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:textColor="@color/text_primary"
                                    android:textSize="17sp"
                                    android:textStyle="bold"
                                    tools:text="0.0 mm" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_holo_index_panel"
                                android:orientation="vertical"
                                android:paddingStart="16dp"
                                android:paddingTop="14dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/home_index_pressure"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/indexPressureValueText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:textColor="@color/text_primary"
                                    android:textSize="17sp"
                                    android:textStyle="bold"
                                    tools:text="1008 hPa" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@drawable/bg_holo_index_panel"
                                android:orientation="vertical"
                                android:paddingStart="16dp"
                                android:paddingTop="14dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/home_index_visibility"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/indexVisibilityValueText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:textColor="@color/text_primary"
                                    android:textSize="17sp"
                                    android:textStyle="bold"
                                    tools:text="24 km" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_holo_index_panel"
                                android:orientation="vertical"
                                android:paddingStart="16dp"
                                android:paddingTop="14dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/home_index_cloud"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/indexCloudValueText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:textColor="@color/text_primary"
                                    android:textSize="17sp"
                                    android:textStyle="bold"
                                    tools:text="62%" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/clothingContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_holo_clothing_panel"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingTop="16dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="16dp">

                        <LinearLayout
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:background="@drawable/bg_holo_clothing_orb"
                            android:gravity="center"
                            android:orientation="vertical">

                            <com.example.weather.ui.HolographicImageView
                                android:id="@+id/clothingIcon"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:contentDescription="@string/clothing_suggestion"
                                android:src="@drawable/ic_clothing_cool" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/clothingSuggestionText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_primary"
                                android:textSize="19sp"
                                android:textStyle="bold"
                                tools:text="Light summer outfit" />

                            <TextView
                                android:id="@+id/clothingAccessoryText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"
                                tools:text="Bring sun protection" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_holo_section_pill"
                            android:paddingStart="10dp"
                            android:paddingTop="5dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="5dp"
                            android:text="@string/home_ai_badge"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_holo_section_pill"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:text="@string/home_forecast_title"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/forecastRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clipToPadding="false"
                        android:overScrollMode="never"
                        android:paddingStart="4dp"
                        android:paddingEnd="44dp"
                        android:paddingBottom="8dp"
                        tools:itemCount="7"
                        tools:listitem="@layout/item_forecast" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <ImageButton
        android:id="@+id/aiAssistantFab"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:adjustViewBounds="true"
        android:background="@android:color/transparent"
        android:contentDescription="@string/ai_assistant_name"
        android:padding="0dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ai_assistant_icon" />
</FrameLayout>
