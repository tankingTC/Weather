<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="142dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="14dp"
    android:background="@drawable/bg_holo_forecast_card"
    android:paddingStart="16dp"
    android:paddingTop="18dp"
    android:paddingEnd="16dp"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/forecastDateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="5月1日" />

        <TextView
            android:id="@+id/forecastWeekText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            tools:text="周五" />

        <com.example.weather.ui.HolographicImageView
            android:id="@+id/forecastIcon"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_marginTop="14dp"
            android:contentDescription="@string/weather_icon"
            tools:src="@drawable/ic_weather_fallback_cloudy" />

        <TextView
            android:id="@+id/forecastConditionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="多云" />

        <TextView
            android:id="@+id/forecastTempText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="10° / 24°" />
    </LinearLayout>
</FrameLayout>
