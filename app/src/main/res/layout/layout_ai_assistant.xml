<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/assistantSheetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_holo_bottom_sheet"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="14dp"
    android:paddingEnd="18dp"
    android:paddingBottom="12dp">

    <View
        android:layout_width="42dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:alpha="0.6"
        android:background="@drawable/bg_bottom_sheet_handle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai_assistant_name"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/aiSubtitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/ai_subtitle_placeholder"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/closeAiButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_ai_close_button"
            android:contentDescription="@string/ai_close"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/text_primary" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/assistantPromptScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleLine="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/promptClothingChip"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai_prompt_clothing"
                android:textColor="@color/ai_chip_text"
                app:chipBackgroundColor="@color/ai_chip_bg"
                app:chipCornerRadius="18dp"
                app:chipStrokeColor="#A8CFE3F8"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/promptUmbrellaChip"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai_prompt_umbrella"
                android:textColor="@color/ai_chip_text"
                app:chipBackgroundColor="@color/ai_chip_bg"
                app:chipCornerRadius="18dp"
                app:chipStrokeColor="#A8CFE3F8"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/promptPlanChip"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai_prompt_plan"
                android:textColor="@color/ai_chip_text"
                app:chipBackgroundColor="@color/ai_chip_bg"
                app:chipCornerRadius="18dp"
                app:chipStrokeColor="#A8CFE3F8"
                app:chipStrokeWidth="1dp" />
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/aiChatRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_ai_chat_panel"
        android:clipToPadding="false"
        android:minHeight="220dp"
        android:paddingStart="10dp"
        android:paddingTop="12dp"
        android:paddingEnd="10dp"
        android:paddingBottom="12dp" />

    <LinearLayout
        android:id="@+id/assistantComposerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:paddingBottom="4dp">

        <LinearLayout
            android:id="@+id/assistantInputBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_ai_input"
            android:gravity="center_vertical"
            android:minHeight="74dp"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingTop="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="10dp">

            <ImageButton
                android:id="@+id/voiceInputButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_ai_action_pill"
                android:contentDescription="@string/ai_action_voice"
                android:padding="9dp"
                android:src="@android:drawable/ic_btn_speak_now"
                android:tint="@color/text_primary" />

            <EditText
                android:id="@+id/aiInputEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_ai_input_field"
                android:gravity="top|start"
                android:hint="@string/ai_input_hint"
                android:imeOptions="actionSend"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="4"
                android:minHeight="50dp"
                android:minLines="1"
                android:paddingStart="14dp"
                android:paddingTop="12dp"
                android:paddingEnd="14dp"
                android:paddingBottom="12dp"
                android:scrollHorizontally="false"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/sendButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="92dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:text="@string/ai_send"
                android:textColor="@color/white"
                app:backgroundTint="@color/ai_fab_bg"
                app:cornerRadius="18dp"
                app:strokeWidth="0dp" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
